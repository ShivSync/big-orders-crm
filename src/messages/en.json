  "help": {
    "title": "Help & User Guide",
    "navTitle": "Help",
    "searchPlaceholder": "Search help topics...",
    "gettingStarted": "Getting Started",
    "gettingStartedDesc": "Learn the basics of Big Orders CRM — login, navigation, and your first lead.",
    "gettingStartedContent": "Big Orders CRM is designed to manage bulk/corporate/party orders for KFC Vietnam's 260+ stores. After logging in, you'll see the Dashboard with key metrics. Use the sidebar to navigate between modules. Start by creating a Lead, then progress through the pipeline to Orders.",
    "leadsGuide": "Lead Management",
    "leadsGuideDesc": "Create, track, and convert leads through the sales pipeline.",
    "leadsGuideContent": "Leads represent potential customers. Create leads manually or they arrive via Zalo, Facebook, Landing Page, or Discovery Engine. Each lead has a stage: New → Contacted → Qualified → Converted/Lost. Click the stage bar to advance a lead. Add activities (calls, emails, meetings, notes) to track interactions. Qualified leads can be converted to Customers or Opportunities.",
    "pipelineGuide": "Sales Pipeline",
    "pipelineGuideDesc": "Manage opportunities with the visual Kanban board.",
    "pipelineGuideContent": "The Pipeline shows all opportunities as cards in stage columns. Drag cards between columns to change stages. Won requires an actual value. Lost requires a reason. The summary bar shows total pipeline value and conversion rates.",
    "customersGuide": "Customers & Organizations",
    "customersGuideDesc": "Manage individual customers and their organization links.",
    "customersGuideContent": "Customers are converted from leads or created directly. Each customer has revenue stats, order history, and can be linked to organizations. Organizations represent companies, schools, hotels, etc. Use the recurring events feature to track birthdays and anniversaries for proactive outreach.",
    "ordersGuide": "Big Orders",
    "ordersGuideDesc": "Create and manage large party/event orders with the step-by-step wizard.",
    "ordersGuideContent": "Orders flow through: Draft → Confirmed → Preparing → Ready → Fulfilled. The creation wizard guides you: select customer/store, pick menu items, review totals, and confirm. Discounts above the threshold require manager approval. Track payment status (Unpaid/Partial/Paid) and delivery notes.",
    "campaignsGuide": "Campaigns",
    "campaignsGuideDesc": "Send targeted SMS and email campaigns to customer segments.",
    "campaignsGuideContent": "Create campaigns with segment filters (customer type, city, revenue range, last order date). Write templates using variables like {{customer_name}} and {{store_name}}. Preview before sending. Track delivery stats: sent, delivered, failed, bounced.",
    "discoveryGuide": "Discovery Engine",
    "discoveryGuideDesc": "Find new leads near KFC stores using Google Places data.",
    "discoveryGuideContent": "Select a store and scan its territory to discover nearby businesses — schools, companies, hotels, event venues. Each result gets a lead score based on distance, category, and potential. Convert discoveries to leads with one click. Configure API keys in Settings.",
    "channelsGuide": "Channel Integrations",
    "channelsGuideDesc": "Receive and send messages via Zalo, Facebook, SMS, and phone calls.",
    "channelsGuideContent": "Channel messages from Zalo OA and Facebook Messenger are automatically linked to existing leads/customers by phone or social ID. Unknown contacts become new leads. Outbound Zalo ZNS messages must be sent within 48 hours of the customer's last message (Zalo policy). SMS messages are sent via Vihat with the KFC brandname.",
    "chatGuide": "Live Chat",
    "chatGuideDesc": "Respond to website visitors via the embedded chat widget.",
    "chatGuideContent": "The chat bot handles initial inquiries using the FAQ knowledge base. If the bot can't answer, visitors can escalate to a human agent. Chat sessions are linked to leads for follow-up. Manage FAQ entries and chat settings from the Chat admin page.",
    "rolesGuide": "Roles & Permissions",
    "rolesGuideDesc": "Understand the 8-role RBAC system and permission levels.",
    "rolesGuideContent": "The system has 8 roles: Admin, Regional Director, Area Manager, Big Order Manager, Omni-Channel Head, Sales, Call Center, and Marketing. Each role has specific permissions (e.g., leads.view, orders.create). Store filtering controls which stores' data each user can see: ALL, SOME (by team), or ONE (specific store).",
    "settingsGuide": "Settings",
    "settingsGuideDesc": "Configure API keys and system preferences.",
    "settingsGuideContent": "The Settings page lets admins configure API keys for Google Places, Apify, and Firecrawl (used by Discovery Engine). System settings control default behaviors. Only admin users can access Settings.",
    "tips": {
      "title": "Quick Tips",
      "tip1": "Use the stage bar on the lead detail page to quickly advance leads through the pipeline.",
